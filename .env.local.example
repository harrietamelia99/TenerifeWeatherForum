# ──────────────────────────────────────────────────────────────────────────────
# Auto Forecast + Facebook Share Setup
# Copy relevant values to Vercel → Settings → Environment Variables.
# ──────────────────────────────────────────────────────────────────────────────

# ── AI Forecast (daily cron job) ──────────────────────────────────────────────

# Required: Vercel sets this automatically for cron jobs.
# Also used for manual triggers: /api/generate-forecast?secret=YOUR_SECRET
# Generate one with: openssl rand -hex 32
CRON_SECRET=replace_with_your_cron_secret

# Optional: if set, the AI generates natural-language forecast text (GPT-4o-mini).
# If not set, a clean template is used instead — works out of the box, no cost.
# Get a key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ── GitHub API (writes updated forecast to repo, triggers Vercel redeploy) ───

# GitHub Personal Access Token — fine-grained, Contents read+write on this repo only.
# Create at: https://github.com/settings/tokens → Fine-grained tokens
GITHUB_TOKEN=github_pat_replace_with_your_token

# The repo Vercel is deploying from.
GITHUB_REPO=harrietamelia99/TenerifeWeatherForum

# Branch to commit to.
GITHUB_BRANCH=main

# ── Legacy: Kevin's manual Facebook webhook (optional, no longer primary flow) ─

# Only needed if you also want to accept Kevin's manually posted Facebook text.
DAILY_UPDATE_SECRET=replace_with_your_webhook_secret
