# ──────────────────────────────────────────────────────────────────────────────
# Kevin's Daily Update Automation
# Copy this file to .env.local and fill in your values.
# Then add the same variables to Vercel → Settings → Environment Variables.
# ──────────────────────────────────────────────────────────────────────────────

# A random secret string that Make.com will send with every webhook request.
# Generate one with:  openssl rand -hex 32
DAILY_UPDATE_SECRET=replace_with_your_secret_here

# GitHub Personal Access Token with "Contents: Read and write" permission.
# Create one at: https://github.com/settings/tokens → Fine-grained tokens
# Repository access: only "TenerifeWeatherForum"
# Permissions: Contents → Read and write
GITHUB_TOKEN=github_pat_replace_with_your_token

# The GitHub repo that Vercel is deploying from.
GITHUB_REPO=harrietamelia99/TenerifeWeatherForum

# Branch to commit to (leave as main unless you know otherwise).
GITHUB_BRANCH=main
