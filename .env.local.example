# ─────────────────────────────────────────────────────────────
# Add these in Vercel → your project → Settings → Environment Variables
# ─────────────────────────────────────────────────────────────

# Your OpenAI API key — gives the forecast a natural, human writing style.
# Get one free at: https://platform.openai.com/api-keys
# The site works without this (uses a clean template instead).
OPENAI_API_KEY=sk-...

# ─────────────────────────────────────────────────────────────
# Lucky Spin Wheel — required for the /preview/spin feature
# ─────────────────────────────────────────────────────────────

# A long random secret used to sign JWT session tokens.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXTAUTH_SECRET=replace-with-a-random-32-byte-hex-string

# The full URL of your deployment (no trailing slash).
NEXTAUTH_URL=https://your-vercel-domain.vercel.app

# Password to access the /preview/spin/admin panel.
# Choose anything strong — only you need to know it.
ADMIN_PASSWORD_WHEEL=choose-a-strong-password-here

# Email address that receives the monthly winners summary when you hit
# "Archive & Reset Month" in the admin panel. Set this to Kevin's email.
SPIN_NOTIFY_EMAIL=kevinclarkss@yahoo.com
